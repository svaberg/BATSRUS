#INCLUDE
Param/EARLYEARTH/PARAM.neutrals.restartsave.in

#DESCRIPTION
Param/EARLYEARTH/PARAM.neutrals.restartread.in: Stage-2 continuation based on neutrals restartsave baseline		StringDescription

#SAVEINITIAL
T			DoSaveInitial

#SAVERESTART
T			DoSaveRestart
400			DnSaveRestart
-1.0			DtSaveRestart

#SAVEPLOT
3			nPlotFile
y=0 VAR tec		StringPlot
100			DnSavePlot
-1.0			DtSavePlot
{MHD} xuvtau xuvheat fneutral nh nhp ne		NameVars
{default} usexuv xuvfluxsi xuvsigmasi usexuvbshd useheatsrc initsprho nfrwind nfrplan nplscale nfrfloor usechem chmtauatt chmenergy chmlimit chemsub phioncoef recombcoef chemener nchemsub		NamePars
z=0 VAR tec		StringPlot
400			DnSavePlot
-1.0			DtSavePlot
{MHD} xuvtau xuvheat fneutral nh nhp ne		NameVars
{default} usexuv xuvfluxsi xuvsigmasi usexuvbshd useheatsrc initsprho nfrwind nfrplan nplscale nfrfloor usechem chmtauatt chmenergy chmlimit chemsub phioncoef recombcoef chemener nchemsub		NamePars
3d VAR tec		StringPlot
400			DnSavePlot
-1.0			DtSavePlot
{MHD} xuvtau xuvheat fneutral nh nhp ne		NameVars
{default} usexuv xuvfluxsi xuvsigmasi usexuvbshd useheatsrc initsprho nfrwind nfrplan nplscale nfrfloor usechem chmtauatt chmenergy chmlimit chemsub phioncoef recombcoef chemener nchemsub		NamePars

#SAVELOGFILE
T			DoSaveLogfile
VAR			StringLog
100			DnSaveLogfile
-1.0			DtSaveLogfile
dt rho mx my mz p bx by bz pmin pmax dst lon1 lat1 lon2 lat2 status fneutralmin fneutralmax nhmin nhmax nhpmin nhpmax xuvheatmin xuvheatmax		NameLogVars

  Restart-read notes:
  - nStep resets to 0 when this file is run from restart.
  - The baseline restartsave run ended at physical nStep=400.
  - Therefore local MaxIteration=3600 below corresponds to physical nStep=4000.
  - DnSaveRestart=400 guarantees restart outputs at each stage endpoint.

#DOAMR
F			DoAmr

#USERINPUTBEGIN -----------------------------------
#EARTHXUV
F			UseXuv

#EARTHXUVSWITCH
F			UseXuvBodyShadow
F			UseHeatingSource

#EARTHXUVNEUTRALSWITCH
T			UseInitSpeciesFromRho

#EARTHXUVNEUTRALS
0.10			NeutralFracWind [wind/far-field BC neutral fraction]
0.30			NeutralFracPlanet [target neutral fraction near planet]
40.0			NeutralPlanetScale [R, radial ramp length from rBody]
1.0e-6			NeutralFracFloor [technical floor in calculations]
1.0			NeutralFracMax

#EARTHXUVNEUTRALCHEMSWITCH
F			UseNeutralChem [optional H<->Hp chemistry source]
T			UseChemTauAttenuation [scale photoionization with exp(-xuvtau) and body shadow]
F			UseChemEnergyBookkeeping [optional chemistry energy bookkeeping in MHD energy]
T			UseChemSourceLimiter [enforce nonnegative Hp/H after explicit source update]
F			UseChemSubcycling [fixed explicit chemistry subcycling for stiff cells]

#EARTHXUVNEUTRALCHEM
1.0e-7			PhotoIonCoeffSi [1/s, unattenuated H photoionization frequency]
2.6e-19			RecombCoeffSi [m^3/s, H+ + e -> H recombination coefficient]
2.179872e-18		ChemEnergyPerIonSi [J, ionization potential used for net chemistry energy]
4			nChemSubstep [integer, used when UseChemSubcycling=T]
#USERINPUTEND -------------------------------------

#STOP
3600			MaxIteration
-1.0			tSimulationMax

  Stage B (local n=3600->4000): XUV transport only, no heating, no chemistry.
#RUN ##########################################################################

#USERINPUTBEGIN -----------------------------------
#EARTHXUV
T			UseXuv
4.64e-3			XuvFluxSi [W/m^2, modern-Earth-like XUV for gentle turn-on]
1.0e-22			XuvSigmaSi [m^2, effective absorber cross section]

#EARTHXUVSWITCH
F			UseXuvBodyShadow
F			UseHeatingSource

#EARTHXUVNEUTRALSWITCH
T			UseInitSpeciesFromRho

#EARTHXUVNEUTRALS
0.10			NeutralFracWind [wind/far-field BC neutral fraction]
0.30			NeutralFracPlanet [target neutral fraction near planet]
40.0			NeutralPlanetScale [R, radial ramp length from rBody]
1.0e-6			NeutralFracFloor [technical floor in calculations]
1.0			NeutralFracMax

#EARTHXUVNEUTRALCHEMSWITCH
F			UseNeutralChem [optional H<->Hp chemistry source]
T			UseChemTauAttenuation [scale photoionization with exp(-xuvtau) and body shadow]
F			UseChemEnergyBookkeeping [optional chemistry energy bookkeeping in MHD energy]
T			UseChemSourceLimiter [enforce nonnegative Hp/H after explicit source update]
F			UseChemSubcycling [fixed explicit chemistry subcycling for stiff cells]

#EARTHXUVNEUTRALCHEM
1.0e-7			PhotoIonCoeffSi [1/s, unattenuated H photoionization frequency]
2.6e-19			RecombCoeffSi [m^3/s, H+ + e -> H recombination coefficient]
2.179872e-18		ChemEnergyPerIonSi [J, ionization potential used for net chemistry energy]
4			nChemSubstep [integer, used when UseChemSubcycling=T]
#USERINPUTEND -------------------------------------

#STOP
4000			MaxIteration
-1.0			tSimulationMax

  Stage C1 (local n=4000->4400): turn on XUV heating at low flux.
#RUN ##########################################################################

#USERINPUTBEGIN -----------------------------------
#EARTHXUV
T			UseXuv
4.64e-3			XuvFluxSi [W/m^2, heating enabled at low flux]
1.0e-22			XuvSigmaSi [m^2, effective absorber cross section]

#EARTHXUVSWITCH
F			UseXuvBodyShadow
T			UseHeatingSource

#EARTHXUVNEUTRALSWITCH
T			UseInitSpeciesFromRho

#EARTHXUVNEUTRALS
0.10			NeutralFracWind [wind/far-field BC neutral fraction]
0.30			NeutralFracPlanet [target neutral fraction near planet]
40.0			NeutralPlanetScale [R, radial ramp length from rBody]
1.0e-6			NeutralFracFloor [technical floor in calculations]
1.0			NeutralFracMax

#EARTHXUVNEUTRALCHEMSWITCH
F			UseNeutralChem [optional H<->Hp chemistry source]
T			UseChemTauAttenuation [scale photoionization with exp(-xuvtau) and body shadow]
F			UseChemEnergyBookkeeping [optional chemistry energy bookkeeping in MHD energy]
T			UseChemSourceLimiter [enforce nonnegative Hp/H after explicit source update]
F			UseChemSubcycling [fixed explicit chemistry subcycling for stiff cells]

#EARTHXUVNEUTRALCHEM
1.0e-7			PhotoIonCoeffSi [1/s, unattenuated H photoionization frequency]
2.6e-19			RecombCoeffSi [m^3/s, H+ + e -> H recombination coefficient]
2.179872e-18		ChemEnergyPerIonSi [J, ionization potential used for net chemistry energy]
4			nChemSubstep [integer, used when UseChemSubcycling=T]
#USERINPUTEND -------------------------------------

#STOP
4400			MaxIteration
-1.0			tSimulationMax

  Stage C2 (local n=4400->5200): ramp heating flux and enable body shadow.
#RUN ##########################################################################

#USERINPUTBEGIN -----------------------------------
#EARTHXUV
T			UseXuv
4.64e-1			XuvFluxSi [W/m^2, 100x modern flux ramp step]
1.0e-22			XuvSigmaSi [m^2, effective absorber cross section]

#EARTHXUVSWITCH
T			UseXuvBodyShadow
T			UseHeatingSource

#EARTHXUVNEUTRALSWITCH
T			UseInitSpeciesFromRho

#EARTHXUVNEUTRALS
0.10			NeutralFracWind [wind/far-field BC neutral fraction]
0.30			NeutralFracPlanet [target neutral fraction near planet]
40.0			NeutralPlanetScale [R, radial ramp length from rBody]
1.0e-6			NeutralFracFloor [technical floor in calculations]
1.0			NeutralFracMax

#EARTHXUVNEUTRALCHEMSWITCH
F			UseNeutralChem [optional H<->Hp chemistry source]
T			UseChemTauAttenuation [scale photoionization with exp(-xuvtau) and body shadow]
F			UseChemEnergyBookkeeping [optional chemistry energy bookkeeping in MHD energy]
T			UseChemSourceLimiter [enforce nonnegative Hp/H after explicit source update]
F			UseChemSubcycling [fixed explicit chemistry subcycling for stiff cells]

#EARTHXUVNEUTRALCHEM
1.0e-7			PhotoIonCoeffSi [1/s, unattenuated H photoionization frequency]
2.6e-19			RecombCoeffSi [m^3/s, H+ + e -> H recombination coefficient]
2.179872e-18		ChemEnergyPerIonSi [J, ionization potential used for net chemistry energy]
4			nChemSubstep [integer, used when UseChemSubcycling=T]
#USERINPUTEND -------------------------------------

#STOP
5200			MaxIteration
-1.0			tSimulationMax

  Stage D (local n=5200->6800): enable chemistry with limiter+subcycling.
#RUN ##########################################################################

#SAVEPLOT
3			nPlotFile
y=0 VAR tec		StringPlot
50			DnSavePlot
-1.0			DtSavePlot
{MHD} xuvtau xuvheat fneutral nh nhp ne		NameVars
{default} usexuv xuvfluxsi xuvsigmasi usexuvbshd useheatsrc initsprho nfrwind nfrplan nplscale nfrfloor usechem chmtauatt chmenergy chmlimit chemsub phioncoef recombcoef chemener nchemsub		NamePars
z=0 VAR tec		StringPlot
200			DnSavePlot
-1.0			DtSavePlot
{MHD} xuvtau xuvheat fneutral nh nhp ne		NameVars
{default} usexuv xuvfluxsi xuvsigmasi usexuvbshd useheatsrc initsprho nfrwind nfrplan nplscale nfrfloor usechem chmtauatt chmenergy chmlimit chemsub phioncoef recombcoef chemener nchemsub		NamePars
3d VAR tec		StringPlot
200			DnSavePlot
-1.0			DtSavePlot
{MHD} xuvtau xuvheat fneutral nh nhp ne		NameVars
{default} usexuv xuvfluxsi xuvsigmasi usexuvbshd useheatsrc initsprho nfrwind nfrplan nplscale nfrfloor usechem chmtauatt chmenergy chmlimit chemsub phioncoef recombcoef chemener nchemsub		NamePars

#USERINPUTBEGIN -----------------------------------
#EARTHXUV
T			UseXuv
4.64e-1			XuvFluxSi [W/m^2, keep flux fixed while chemistry is enabled]
1.0e-22			XuvSigmaSi [m^2, effective absorber cross section]

#EARTHXUVSWITCH
T			UseXuvBodyShadow
T			UseHeatingSource

#EARTHXUVNEUTRALSWITCH
T			UseInitSpeciesFromRho

#EARTHXUVNEUTRALS
0.10			NeutralFracWind [wind/far-field BC neutral fraction]
0.30			NeutralFracPlanet [target neutral fraction near planet]
40.0			NeutralPlanetScale [R, radial ramp length from rBody]
1.0e-6			NeutralFracFloor [technical floor in calculations]
1.0			NeutralFracMax

#EARTHXUVNEUTRALCHEMSWITCH
T			UseNeutralChem [optional H<->Hp chemistry source]
T			UseChemTauAttenuation [scale photoionization with exp(-xuvtau) and body shadow]
F			UseChemEnergyBookkeeping [optional chemistry energy bookkeeping in MHD energy]
T			UseChemSourceLimiter [enforce nonnegative Hp/H after explicit source update]
T			UseChemSubcycling [fixed explicit chemistry subcycling for stiff cells]

#EARTHXUVNEUTRALCHEM
1.0e-7			PhotoIonCoeffSi [1/s, unattenuated H photoionization frequency]
2.6e-19			RecombCoeffSi [m^3/s, H+ + e -> H recombination coefficient]
2.179872e-18		ChemEnergyPerIonSi [J, ionization potential used for net chemistry energy]
4			nChemSubstep [integer, used when UseChemSubcycling=T]
#USERINPUTEND -------------------------------------

#STOP
6800			MaxIteration
-1.0			tSimulationMax

  Stage E (local n=6800->8400): enable chemistry energy bookkeeping.
#RUN ##########################################################################

#SAVEPLOT
3			nPlotFile
y=0 VAR tec		StringPlot
50			DnSavePlot
-1.0			DtSavePlot
{MHD} xuvtau xuvheat fneutral nh nhp ne		NameVars
{default} usexuv xuvfluxsi xuvsigmasi usexuvbshd useheatsrc initsprho nfrwind nfrplan nplscale nfrfloor usechem chmtauatt chmenergy chmlimit chemsub phioncoef recombcoef chemener nchemsub		NamePars
z=0 VAR tec		StringPlot
200			DnSavePlot
-1.0			DtSavePlot
{MHD} xuvtau xuvheat fneutral nh nhp ne		NameVars
{default} usexuv xuvfluxsi xuvsigmasi usexuvbshd useheatsrc initsprho nfrwind nfrplan nplscale nfrfloor usechem chmtauatt chmenergy chmlimit chemsub phioncoef recombcoef chemener nchemsub		NamePars
3d VAR tec		StringPlot
200			DnSavePlot
-1.0			DtSavePlot
{MHD} xuvtau xuvheat fneutral nh nhp ne		NameVars
{default} usexuv xuvfluxsi xuvsigmasi usexuvbshd useheatsrc initsprho nfrwind nfrplan nplscale nfrfloor usechem chmtauatt chmenergy chmlimit chemsub phioncoef recombcoef chemener nchemsub		NamePars

#USERINPUTBEGIN -----------------------------------
#EARTHXUV
T			UseXuv
4.64e-1			XuvFluxSi [W/m^2, keep flux fixed for energy-bookkeeping turn-on]
1.0e-22			XuvSigmaSi [m^2, effective absorber cross section]

#EARTHXUVSWITCH
T			UseXuvBodyShadow
T			UseHeatingSource

#EARTHXUVNEUTRALSWITCH
T			UseInitSpeciesFromRho

#EARTHXUVNEUTRALS
0.10			NeutralFracWind [wind/far-field BC neutral fraction]
0.30			NeutralFracPlanet [target neutral fraction near planet]
40.0			NeutralPlanetScale [R, radial ramp length from rBody]
1.0e-6			NeutralFracFloor [technical floor in calculations]
1.0			NeutralFracMax

#EARTHXUVNEUTRALCHEMSWITCH
T			UseNeutralChem [optional H<->Hp chemistry source]
T			UseChemTauAttenuation [scale photoionization with exp(-xuvtau) and body shadow]
T			UseChemEnergyBookkeeping [optional chemistry energy bookkeeping in MHD energy]
T			UseChemSourceLimiter [enforce nonnegative Hp/H after explicit source update]
T			UseChemSubcycling [fixed explicit chemistry subcycling for stiff cells]

#EARTHXUVNEUTRALCHEM
1.0e-7			PhotoIonCoeffSi [1/s, unattenuated H photoionization frequency]
2.6e-19			RecombCoeffSi [m^3/s, H+ + e -> H recombination coefficient]
2.179872e-18		ChemEnergyPerIonSi [J, ionization potential used for net chemistry energy]
4			nChemSubstep [integer, used when UseChemSubcycling=T]
#USERINPUTEND -------------------------------------

#STOP
8400			MaxIteration
-1.0			tSimulationMax
